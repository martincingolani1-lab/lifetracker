VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Fit API (para sincronización de pasos con Samsung Health)
# Instrucciones de configuración:
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Habilita la API de Google Fit
# 4. Ve a "Credenciales" y crea credenciales OAuth 2.0
# 5. Agrega http://localhost:5173 como origen autorizado
# 6. Copia el Client ID y API Key aquí
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your_api_key_here
