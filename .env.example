NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Fit API (para sincronización de pasos con Samsung Health)
# Instrucciones de configuración:
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Habilita la API de Google Fit
# 4. Ve a "Credenciales" y crea credenciales OAuth 2.0
# 5. Agrega http://localhost:3000 como origen autorizado (Next.js usa puerto 3000)
# 6. Copia el Client ID y API Key aquí
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_API_KEY=your_api_key_here
